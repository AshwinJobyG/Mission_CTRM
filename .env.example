# Copy to .env and adjust. All values are optional (defaults shown).

# Local Ollama server
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# Storage / data
DATA_DIR=./data
CHROMA_DIR=./chroma_db
COLLECTION=knowledge

# Chunking & retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5

# Ollama read timeout (seconds) — budget for model load + generation. Raise
# this if you hit "timed out" on first/cold queries with a large model.
OLLAMA_TIMEOUT=300
# Short connect timeout so an unreachable server fails fast.
OLLAMA_CONNECT_TIMEOUT=10

# Performance: keep the model resident between queries (avoids per-query
# reloads / chat<->embed model swapping). "-1" keeps it loaded indefinitely.
OLLAMA_KEEP_ALIVE=30m
# Cap generated tokens and the context window to bound latency.
NUM_PREDICT=512
NUM_CTX=4096
