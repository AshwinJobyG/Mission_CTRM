# Copy to .env and adjust. All values are optional (defaults shown).

# Local Ollama server
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# Storage / data
DATA_DIR=./data
CHROMA_DIR=./chroma_db
COLLECTION=knowledge

# Chunking & retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5

# Ollama request timeout (seconds)
OLLAMA_TIMEOUT=120
