# Copy to .env and fill in. Secrets come from the environment ONLY — never commit real values.

# --- Instance ---
JIRA_BASE_URL=https://your-domain.atlassian.net

# --- Auth mode: "cloud" (email + API token) or "server" (PAT) ---
JIRA_AUTH_MODE=cloud

# Cloud (JIRA Cloud, REST v3): Basic auth with email + API token
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_api_token_here

# Server / Data Center (REST v2): Bearer auth with a Personal Access Token
# JIRA_PAT=your_personal_access_token_here

# --- Tuning ---
JIRA_TIMEOUT_MS=4000     # per-call timeout; exceeding it => down
JIRA_DEGRADED_MS=1500    # slower-than-this 200s => degraded (must be < TIMEOUT_MS)
JIRA_MAX_RESULTS=20      # default search result cap
