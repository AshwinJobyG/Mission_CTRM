# Copy to .env and fill in. Secrets come from the environment ONLY — never commit real values.

# --- Instance ---
JIRA_BASE_URL=https://your-domain.atlassian.net

# --- Auth mode: "cloud" (email + API token) or "server" (PAT) ---
JIRA_AUTH_MODE=cloud

# Cloud (JIRA Cloud, REST v3): Basic auth with email + API token
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_api_token_here

# Server / Data Center (REST v2): Bearer auth with a Personal Access Token
# JIRA_PAT=your_personal_access_token_here

# --- Tuning ---
JIRA_TIMEOUT_MS=4000     # per-call timeout; exceeding it => down
JIRA_DEGRADED_MS=1500    # slower-than-this 200s => degraded (must be < TIMEOUT_MS)
JIRA_MAX_RESULTS=20      # default search result cap

# --- TLS / corporate certificates ---
# Preferred: point at your company CA bundle (PEM) so TLS is still verified.
# JIRA_CA_BUNDLE=C:\path\to\company-ca.pem
# Quick workaround for self-signed/internal certs (disables verification — dev only):
# JIRA_VERIFY_SSL=false

# --- Company-hosted ION LLM (chat + embeddings for the RAG flow) ---
# OpenAI-compatible endpoint; the connector appends "/v1".
ION_LLM_API_URL=https://llm.your-company.internal
ION_LLM_API_KEY=your_ion_llm_api_key
ION_LLM_MODEL=your-chat-model-name
ION_LLM_MAX_TOKENS=30000

# --- Embeddings backend for the vector DB (index / ask / chat) ---
# EMBED_PROVIDER: ion | ollama | local   (run `python -m jira_connector.cli embed-check`)
EMBED_PROVIDER=ion

# ion: requires an embeddings model on your ION gateway
ION_LLM_EMBED_MODEL=your-embeddings-model-name
# Set true to verify TLS on ION calls (default false, mirrors the ION chat client).
ION_VERIFY_SSL=false

# ollama fallback (works offline; run `ollama pull nomic-embed-text`)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# local fallback (sentence-transformers; first run downloads the model)
EMBED_LOCAL_MODEL=all-MiniLM-L6-v2

# --- Vector DB (Chroma) ---
JIRA_CHROMA_DIR=./jira_chroma_db
JIRA_COLLECTION=jira_knowledge
