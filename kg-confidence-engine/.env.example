# kg-confidence-engine — copy to .env (the .env file is gitignored).
# Decision synthesis (Phase 4) picks a backend automatically; see KGCE_LLM_BACKEND.

# --- Company-hosted, OpenAI-compatible LLM (ION) — preferred when set ---------
ION_LLM_API_URL=https://your-ion-host        # base; the client appends /v1
ION_LLM_API_KEY=your-ion-key
ION_LLM_MODEL=your-ion-model
# ION tuning (optional):
KGCE_ION_MAX_TOKENS=4000
KGCE_ION_VERIFY_SSL=false                     # mirrors the supplied httpx(verify=False)

# --- Anthropic (used only if ION is not configured) --------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# --- Backend / embedding selection -------------------------------------------
# KGCE_LLM_BACKEND=auto         # auto | ion | anthropic | extractive
# KGCE_EMBED_BACKEND=auto       # auto | st | hashing
# KGCE_ST_MODEL=all-MiniLM-L6-v2   # local path or HF id for the embedder
